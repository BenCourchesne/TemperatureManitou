{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "backups/**",
      "mockups/**",
      "**/.*",
      "**/.*/**",
      ".git/**",
      ".firebase/**",
      "__pycache__/**",
      "**/node_modules/**",
      "*.gs",
      "*.yaml",
      "*.py",
      "LakeManitou Logo V2.png",
      "*.jpg",
      "*.md",
      "appsscript.json",
      "wireframes.html"
    ],
    "rewrites": [
      { "source": "/cp", "destination": "/cp.html" }
    ]
  }
}
